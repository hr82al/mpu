{
  "permissions": {
    "allow": [
      "Bash(MPU_ENV_PASS=testpass123 ./scripts/envault.sh changed .env .env.enc)",
      "Bash(MPU_ENV_PASS=testpass123 make env-sync)",
      "Bash(MPU_ENV_PASS=testpass123 make ensure-env)",
      "Bash(MPU_ENV_PASS=testpass123 ./scripts/envault.sh encrypt .env .env.enc <<< \"y\")",
      "Bash(MPU_ENV_PASS=test123 MPU_ENV_YES=1 ./scripts/envault.sh encrypt .env .env.enc)",
      "Bash(MPU_ENV_PASS=test123 MPU_ENV_YES=1 ./scripts/envault.sh decrypt .env.enc /tmp/env_rt)",
      "Bash(MPU_ENV_PASS=wrong MPU_ENV_YES=1 ./scripts/envault.sh decrypt .env.enc /tmp/env_bad)",
      "Bash(echo \"wrong_pass exit=$?\")",
      "Bash(MPU_ENV_SKIP=1 ./scripts/envault.sh encrypt .env .env.enc)"
    ]
  }
}
