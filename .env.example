# mpu environment variables
# Copy this file to ~/.config/mpu/.env (XDG_CONFIG_HOME) and fill in real values.
# mpu loads only ~/.config/mpu/.env, never the file in the repo, so secrets stay out of git.
#
# Все пароли / токены / ключи / сессии в этом примере оставлены ПУСТЫМИ — заполнить своими.

# ──────────────────────────────────────────────────────────────────────────────
# WB Plus Apps Script webapp (Google Sheets writer)
# URL — deployment-ссылка вида https://script.google.com/macros/s/<deploy-id>/exec
# ──────────────────────────────────────────────────────────────────────────────
WB_PLUS_WEB_APP_URL=
WB_PLUS_WEB_APP_EMAIL=

# ──────────────────────────────────────────────────────────────────────────────
# PostgreSQL — личные креды и admin-доступ
# ──────────────────────────────────────────────────────────────────────────────
PG_MY_USER_NAME=
PG_MY_USER_PASSWORD=
PG_NAME=
PG_PASSWORD=

# ──────────────────────────────────────────────────────────────────────────────
# sl-back API (used by mpu api-* commands)
# ──────────────────────────────────────────────────────────────────────────────
# Креды для POST /auth/login. Токен кэшируется в ~/.config/mpu/.api-token.json (TTL 10 мин).
TOKEN_EMAIL=
TOKEN_PASSWORD=

# Host где sl-back лежит (без trailing slash).
NEXT_PUBLIC_SERVER_URL=https://mp.btlz-api.ru
# API path prefix. Может быть полным URL ("https://...") — тогда NEXT_PUBLIC_SERVER_URL не нужен.
BASE_API_URL=https://mp.btlz-api.ru

# ──────────────────────────────────────────────────────────────────────────────
# 10X (sw-back) admin API (used by mpu search <email>)
# X10_LOGIN/X10_PASSWORD — staff-аккаунт 10X (ОТДЕЛЬНАЯ от sl-back auth-система).
# ──────────────────────────────────────────────────────────────────────────────
X10_URL=https://system10x.btlz-api.ru
X10_LOGIN=
X10_PASSWORD=

# ──────────────────────────────────────────────────────────────────────────────
# Окружение
# ──────────────────────────────────────────────────────────────────────────────
ENV_TYPE=dev
PROTECT=true

# DEV workspaces PG (прямой psql к workspaces на dev-стенде)
DEV_WORKSPACES_USER=
DEV_WORKSPACES_PASSWORD=

# ──────────────────────────────────────────────────────────────────────────────
# GitLab REST API (used by mpu mr / mpu glab-status) — code-review комментарии в MR.
# Personal access token со scope `api`: GitLab → Preferences → Access Tokens.
# ──────────────────────────────────────────────────────────────────────────────
GLAB_TOKEN=
# Инстанс GitLab (без trailing slash). По умолчанию https://gitlab.btlz-api.ru
GITLAB_BASE_URL=

# ──────────────────────────────────────────────────────────────────────────────
# Kaiten REST API (used by mpu kiten)
# API key from https://btlz.kaiten.ru/profile/api-key
# ──────────────────────────────────────────────────────────────────────────────
KITEN_API_KEY=
KITEN_BASE_URL=https://btlz.kaiten.ru

# `mpu init` кэширует spaces/boards/lanes/columns в ~/.config/mpu/mpu.db для автодополнения
# и резолва --space/--board/--lane/--column (ID или подстрока названия). Обновить: `mpu init`
# или `mpu kiten spaces` / `boards` / `lanes` / `columns`.
#
# mpu kiten ls — фильтры по умолчанию. CLI-флаг переопределяет ТОЛЬКО свою ось,
# остальные оси остаются из .env (поосный coalesce).
KITEN_LS_CONDITION=1            # 1=активные (на доске), 2=архив. Флаг: --archived
KITEN_LS_STATES=               # csv 1=queued,2=inProgress,3=done; пусто=все. Флаг: --state
KITEN_LS_SPACE_ID=             # ограничить пространством. Флаг: --space
KITEN_LS_BOARD_ID=             # ограничить доской. Флаг: --board
KITEN_LS_LANE_ID=              # ограничить дорожкой. Флаг: --lane
KITEN_LS_COLUMN_ID=            # ограничить колонкой (столбцом). Флаг: --column

# Маппинг колонок: для `mpu kiten ls --format '... {column_mapped} ...'` и для
# отчёта `mpu telegram status` (заменяет имя колонки в строке карточки).
# JSON-объект: ключ — название колонки (ИЛИ её id), значение — метка.
# Пример: KITEN_COLUMN_MAP='{"Тут только выполненные карточки!": "Выполнено"}'
KITEN_COLUMN_MAP=

# ──────────────────────────────────────────────────────────────────────────────
# Локальный PG (dev-стек)
# ──────────────────────────────────────────────────────────────────────────────
PG_DB_NAME=wb
PG_LOCAL_PORT=5441
PG_PORT=5432
PG_MAIN_USER_NAME=wb_plus_db_admin
PG_MAIN_USER_PASSWORD=
PG_CLIENT_USER_PASSWORD=

# ──────────────────────────────────────────────────────────────────────────────
# Redis (dev-стек)
# ──────────────────────────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_USER=mp-redis-user
REDIS_USER_PASSWORD=

# ──────────────────────────────────────────────────────────────────────────────
# NATS (dev-стек)
# ──────────────────────────────────────────────────────────────────────────────
NATS_SERVERS="nats://mp-nats:4222"
NATS_JETSTREAM_SERVERS="nats://mp-nats:4222"
USE_NATS_PROXY=true

# ──────────────────────────────────────────────────────────────────────────────
# Loaders / processor threads (dev-стек)
# ──────────────────────────────────────────────────────────────────────────────
DATA_LOADER_CYCLE=2
DATA_LOADER_THREADS=0
WB_LOADER_THREADS=0
OZON_LOADER_THREADS=0
SS_LOADER_THREADS=0
SS_UPDATER_THREADS=0
DATA_PROCESSOR_THREADS=0

# ──────────────────────────────────────────────────────────────────────────────
# sl-back instance (dev-стек)
# ──────────────────────────────────────────────────────────────────────────────
INTERNAL_API_SERVICE_KEY=
SERVER_NAME=sl-0
SERVER_NUMBER=0
API_PORT=5000
CLIENT_URL=http://localhost:2999,http://localhost:3000
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
SMTP_HOST=""
SMTP_PORT=465
SMTP_USER=""
SMTP_PASSWORD=
NEXT_PRIVATE_API_URL=http://localhost:5000

# ──────────────────────────────────────────────────────────────────────────────
# Miro REST API (used by mpu d2-miro)
# Personal access token from https://miro.com/app/settings/user-profile/apps
# ──────────────────────────────────────────────────────────────────────────────
MIRO_TOKEN=
# Default board ID (URL-форма, напр. uXjVJqkHSQc=). Override per-call с --board.
MIRO_BOARD_ID=

# ──────────────────────────────────────────────────────────────────────────────
# Portainer (used by node-CLI обёрток через Portainer API)
# API key from Portainer → My account → Access tokens.
# ──────────────────────────────────────────────────────────────────────────────
PORTAINER_URL=https://192.168.150.12:9443
PORTAINER_API_KEY=

# ──────────────────────────────────────────────────────────────────────────────
# Loki (used by mpu logs)
# ──────────────────────────────────────────────────────────────────────────────
LOKI_URL=http://192.168.150.5:3100

# ──────────────────────────────────────────────────────────────────────────────
# Server DNS — резолв селекторов pg_N / sl_N → IP (lib/servers.py)
# ──────────────────────────────────────────────────────────────────────────────
pg_0=192.168.150.30
pg_1=192.168.150.31
pg_2=192.168.150.32
pg_3=192.168.150.33
pg_4=192.168.150.34
pg_5=192.168.150.7
pg_6=192.168.150.36
pg_7=192.168.150.37
pg_8=192.168.150.38
pg_9=192.168.150.39
pg_10=192.168.150.45
pg_11=192.168.150.47
pg_12=192.168.150.52
pg_13=192.168.150.53
pg_14=192.168.150.54

sl_0=192.168.150.90
sl_1=192.168.150.91
sl_2=192.168.150.92
sl_3=192.168.150.93
sl_4=192.168.150.94
sl_5=192.168.150.95
sl_6=192.168.150.96
sl_7=192.168.150.97
sl_8=192.168.150.98
sl_9=192.168.150.99
sl_10=192.168.150.46
sl_11=192.168.159.24
sl_12=192.168.150.49
sl_13=192.168.150.50
sl_14=192.168.150.51

# ──────────────────────────────────────────────────────────────────────────────
# Telegram (used by mpu telegram) — отправка от имени пользователя (telethon).
# API ID / HASH получить на https://my.telegram.org → API development tools.
# ──────────────────────────────────────────────────────────────────────────────
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Телефон для входа (опц.). Если пусто — `mpu init` спросит интерактивно.
TELEGRAM_PHONE=

# StringSession. НЕ заполнять вручную — пишется автоматически при `mpu init`
# (один раз, интерактивный вход: код из Telegram → опц. 2FA). Чтобы перелогиниться —
# очистить эту переменную и снова запустить `mpu init`.
TELEGRAM_SESSION=

# Адресат по умолчанию для `mpu telegram send` (если не задан --chat).
# @username / числовой id / ссылка t.me / телефон / me (Избранное). Найти id — `mpu telegram ls`.
TELEGRAM_DEFAULT_CHAT=me

# Прокси ТОЛЬКО для telethon (mpu telegram), если Telegram недоступен напрямую.
# Схемы: http/https/socks5/socks4. Формат: scheme://[user:pass@]host:port
# ВАЖНО: не клади сюда HTTPS_PROXY — это стандартное имя, dotenv протащит его в окружение
# процесса, и весь HTTP-трафик mpu (kaiten и пр.) пойдёт через прокси (вплоть до зависаний на
# недоступных хостах). Для прокси под Telegram — именно TELEGRAM_PROXY.
TELEGRAM_PROXY=
