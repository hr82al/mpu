{
  "name": "mpu",
  "version": "0.1.0",
  "description": "Multi-purpose CLI utility",
  "type": "module",
  "bin": {
    "new-mpu": "./dist/bin/mpu.js",
    "sheet": "./dist/bin/sheet.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/bin/mpu.js dist/bin/sheet.js",
    "dev": "tsc --watch",
    "start": "node dist/bin/mpu.js",
    "test": "NODE_OPTIONS='--experimental-vm-modules --disable-warning=ExperimentalWarning' jest",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules --disable-warning=ExperimentalWarning' jest --watch",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules --disable-warning=ExperimentalWarning' jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "eslint": "^9.15.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.16.0"
  }
}
